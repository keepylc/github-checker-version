# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID чата, куда слать уведомления (узнать у @userinfobot)
CHAT_ID=123456789

# Интервал проверки в секундах (по умолчанию 3600 = 1 час)
CHECK_INTERVAL=3600

# Репозиторий для отслеживания по умолчанию (добавляется при первом запуске).
# Остальные репозитории добавляются через команду /add в боте.
GITHUB_REPO=MHSanaei/3x-ui

# Папка для хранения repos.json и versions.json (опционально, по умолчанию текущая директория)
# DATA_DIR=/app/data
